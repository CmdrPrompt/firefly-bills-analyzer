# firefly-bills-analyzer — configuration template
# Copy to .env and fill in your values. Never commit .env to version control.

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

FIREFLY_URL=https://firefly.example.com
FIREFLY_TOKEN=your-personal-access-token

# ---------------------------------------------------------------------------
# Analysis (optional — defaults shown)
# ---------------------------------------------------------------------------

# LOOKBACK_MONTHS=24
# MIN_OCCURRENCES=2
# AMOUNT_MARGIN=0.10
# HIGH_CONFIDENCE_THRESHOLD=0.80
# CATEGORY_CONFIDENCE_BOOST=0.15
# UNCATEGORIZED_BEHAVIOR=neutral
# INCLUDE_CATEGORIES=
# EXCLUDE_CATEGORIES=

# ---------------------------------------------------------------------------
# Output (optional — defaults shown)
# ---------------------------------------------------------------------------

# DRY_RUN=false
# EXPORT_FORMAT=none

# ---------------------------------------------------------------------------
# Web server (optional — defaults shown)
# ---------------------------------------------------------------------------

# WEB_PORT=5000
# WEB_HOST=127.0.0.1

# ---------------------------------------------------------------------------
# Cache (optional — defaults shown, TTL in seconds)
# ---------------------------------------------------------------------------

# CACHE_DIR=./cache
# CACHE_TTL_CATEGORIES=86400
# CACHE_TTL_BILLS=3600
# CACHE_TTL_TRANSACTIONS=3600
# CACHE_TTL_PAYEES=86400
